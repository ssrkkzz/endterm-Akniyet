def check_keys(data):
    required = ["alpha", "n_iter", "name"]
    errors = []
    for key in required:
        if key not in data:
            errors.append(f"Missing key: {key}")
    return errors
if __name__ == "__main__":
    data = {"alpha": 0.5, "n_iter": 100}
    print(check_keys(data))
