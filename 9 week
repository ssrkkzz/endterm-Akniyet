import json

REQUIRED_KEYS = {"alpha", "n_iter", "name"}

def load_json(path: str):
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
    return data

def check_keys(data: dict):
    missing = REQUIRED_KEYS - set(data.keys())
    return list(missing)

data = load_json("settings.json")
result = check_keys(data)

if not result:
    print("Все ключи есть")
else:
    print("Отсутствуют:", result)
